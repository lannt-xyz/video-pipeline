{
  "_meta": {
    "description": "SDXL txt2img with IPAdapter for character consistency. Uses IPAdapterUnifiedLoader + IPAdapterAdvanced (new API).",
    "checkpoint": "ponyDiffusionV6XL_v6StartWithThisOne.safetensors",
    "ipadapter": "ip-adapter-plus_sdxl_vit-h.safetensors",
    "loras": ["ink_wash_painting.safetensors", "xianxia_fantasy.safetensors", "manhua_style_v2.safetensors", "dark_horror_atmosphere.safetensors"],
    "placeholders": {
      "SCENE_PROMPT": "Positive prompt in English",
      "NEGATIVE_PROMPT": "Negative prompt",
      "WIDTH": 720,
      "HEIGHT": 1280,
      "SEED": 42,
      "ANCHOR_PATH": "/absolute/path/to/anchor.png"
    },
    "required_nodes": [
      "CheckpointLoaderSimple", "LoraLoader", "CLIPTextEncode", "KSampler",
      "VAEDecode", "SaveImage", "IPAdapterUnifiedLoader", "IPAdapterAdvanced",
      "LoadImage"
    ]
  },
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "ponyDiffusionV6XL_v6StartWithThisOne.safetensors"
    }
  },
  "2": {
    "class_type": "LoraLoader",
    "inputs": {
      "model": ["1", 0],
      "clip": ["1", 1],
      "lora_name": "ink_wash_painting.safetensors",
      "strength_model": 0.6,
      "strength_clip": 0.6
    }
  },
  "3": {
    "class_type": "LoraLoader",
    "inputs": {
      "model": ["2", 0],
      "clip": ["2", 1],
      "lora_name": "xianxia_fantasy.safetensors",
      "strength_model": 0.5,
      "strength_clip": 0.5
    }
  },
  "4": {
    "class_type": "LoraLoader",
    "inputs": {
      "model": ["3", 0],
      "clip": ["3", 1],
      "lora_name": "manhua_style_v2.safetensors",
      "strength_model": 0.7,
      "strength_clip": 0.7
    }
  },
  "5": {
    "class_type": "LoraLoader",
    "inputs": {
      "model": ["4", 0],
      "clip": ["4", 1],
      "lora_name": "dark_horror_atmosphere.safetensors",
      "strength_model": 0.4,
      "strength_clip": 0.4
    }
  },
  "6": {
    "class_type": "IPAdapterUnifiedLoader",
    "inputs": {
      "model": ["5", 0],
      "preset": "PLUS (high strength)",
      "lora_strength": 0.6,
      "provider": "CPU"
    }
  },
  "7": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "__ANCHOR_PATH__"
    }
  },
  "8": {
    "class_type": "IPAdapterAdvanced",
    "inputs": {
      "model": ["6", 0],
      "ipadapter": ["6", 1],
      "image": ["7", 0],
      "weight": 0.8,
      "weight_type": "ease in-out",
      "start_at": 0.0,
      "end_at": 1.0,
      "combine_embeds": "concat",
      "embeds_scaling": "K+V w/ C penalty"
    }
  },
  "9": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "__SCENE_PROMPT__, score_9, score_8_up, score_7_up, masterpiece, best quality, highly detailed",
      "clip": ["5", 1]
    }
  },
  "10": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "__NEGATIVE_PROMPT__, score_1, score_2, score_3, score_4, nsfw",
      "clip": ["5", 1]
    }
  },
  "11": {
    "class_type": "EmptyLatentImage",
    "inputs": {
      "width": "__WIDTH__",
      "height": "__HEIGHT__",
      "batch_size": 1
    }
  },
  "12": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["8", 0],
      "positive": ["9", 0],
      "negative": ["10", 0],
      "latent_image": ["11", 0],
      "seed": "__SEED__",
      "steps": 28,
      "cfg": 6.0,
      "sampler_name": "dpmpp_2m_sde",
      "scheduler": "karras",
      "denoise": 1.0
    }
  },
  "13": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["12", 0],
      "vae": ["1", 2]
    }
  },
  "14": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["13", 0],
      "filename_prefix": "character_shot"
    }
  }
}

{
  "_meta": {
    "description": "Flux Dev txt2img scene-only workflow. No IPAdapter/characters. UNETLoader + DualCLIPLoader + SamplerCustomAdvanced pipeline.",
    "model": "flux1-dev-fp8.safetensors",
    "note": "Flux Dev: steps=20, guidance=3.5, scheduler=simple, sampler=euler. No negative prompt. Width/Height/Seed injected at runtime.",
    "placeholders": {
      "SCENE_PROMPT": "Positive prompt in English (comma-separated tags)",
      "WIDTH": 768,
      "HEIGHT": 1024,
      "SEED": 42
    }
  },
  "1": {
    "class_type": "UNETLoader",
    "inputs": {
      "unet_name": "flux1-dev-fp8.safetensors",
      "weight_dtype": "fp8_e4m3fn"
    }
  },
  "2": {
    "class_type": "DualCLIPLoader",
    "inputs": {
      "clip_name1": "clip_l.safetensors",
      "clip_name2": "t5xxl_fp8_e4m3fn.safetensors",
      "type": "flux",
      "device": "default"
    }
  },
  "3": {
    "class_type": "VAELoader",
    "inputs": {
      "vae_name": "ae.safetensors"
    }
  },
  "4": {
    "class_type": "EmptyLatentImage",
    "inputs": {
      "width": "__WIDTH__",
      "height": "__HEIGHT__",
      "batch_size": 1
    }
  },
  "6": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "__SCENE_PROMPT__. Photorealistic cinematic film still, live-action movie frame, realistic skin texture and pores, natural film grain, shot on 35mm anamorphic lens, shallow depth of field, volumetric atmosphere, traditional Chinese rural setting, East Asian visual aesthetic. Style: NOT anime, NOT manga, NOT cartoon, NOT illustration, NOT painting, NOT drawing, NOT 3d render, NOT cgi, NOT cel shading, NOT toon shading, NOT comic book, NOT line art, NOT digital art.",
      "clip": ["2", 0]
    }
  },
  "5": {
    "class_type": "FluxGuidance",
    "inputs": {
      "conditioning": ["6", 0],
      "guidance": 3.5
    }
  },
  "7": {
    "class_type": "BasicGuider",
    "inputs": {
      "model": ["1", 0],
      "conditioning": ["5", 0]
    }
  },
  "9": {
    "class_type": "RandomNoise",
    "inputs": {
      "noise_seed": "__SEED__"
    }
  },
  "10": {
    "class_type": "KSamplerSelect",
    "inputs": {
      "sampler_name": "euler"
    }
  },
  "11": {
    "class_type": "BasicScheduler",
    "inputs": {
      "model": ["1", 0],
      "scheduler": "simple",
      "steps": 20,
      "denoise": 1.0
    }
  },
  "8": {
    "class_type": "SamplerCustomAdvanced",
    "inputs": {
      "noise": ["9", 0],
      "guider": ["7", 0],
      "sampler": ["10", 0],
      "sigmas": ["11", 0],
      "latent_image": ["4", 0]
    }
  },
  "12": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["8", 0],
      "vae": ["3", 0]
    }
  },
  "13": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["12", 0],
      "filename_prefix": "ComfyUI"
    }
  }
}

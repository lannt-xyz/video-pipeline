{
  "_meta": {
    "description": "Thumbnail generation workflow \u2014 16:9 (1280x720) with title and CTA text overlay.",
    "checkpoint": "dreamshaperXL_lightningDPMSDE.safetensors",
    "placeholders": {
      "SCENE_PROMPT": "Positive prompt in English",
      "NEGATIVE_PROMPT": "Negative prompt",
      "WIDTH": 1280,
      "HEIGHT": 720,
      "SEED": 42,
      "TITLE_TEXT": "T\u1eadp 1",
      "CTA_TEXT": "Link bio \ud83d\udc47"
    },
    "required_nodes": [
      "CheckpointLoaderSimple",
      "CLIPTextEncode",
      "KSampler",
      "VAEDecode",
      "DrawText+",
      "SaveImage"
    ]
  },
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "dreamshaperXL_lightningDPMSDE.safetensors"
    }
  },
  "3": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "__SCENE_PROMPT__, masterpiece, best quality, cinematic, wide shot, bright key light, vivid color grading",
      "clip": [
        "1",
        1
      ]
    }
  },
  "4": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "__NEGATIVE_PROMPT__, nsfw, underexposed, dark scene, murky shadows",
      "clip": [
        "1",
        1
      ]
    }
  },
  "5": {
    "class_type": "EmptyLatentImage",
    "inputs": {
      "width": "__WIDTH__",
      "height": "__HEIGHT__",
      "batch_size": 1
    }
  },
  "6": {
    "class_type": "KSampler",
    "inputs": {
      "model": [
        "1",
        0
      ],
      "positive": [
        "3",
        0
      ],
      "negative": [
        "4",
        0
      ],
      "latent_image": [
        "5",
        0
      ],
      "seed": "__SEED__",
      "steps": 8,
      "cfg": 2.0,
      "sampler_name": "dpmpp_sde",
      "scheduler": "karras",
      "denoise": 1.0
    }
  },
  "7": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": [
        "6",
        0
      ],
      "vae": [
        "1",
        2
      ]
    }
  },
  "8": {
    "class_type": "DrawText+",
    "inputs": {
      "text": "__TITLE_TEXT__",
      "font": "ShareTechMono-Regular.ttf",
      "size": 72,
      "color": "#FFFFFF",
      "background_color": "#00000088",
      "shadow_distance": 3,
      "shadow_blur": 2,
      "shadow_color": "#000000",
      "horizontal_align": "left",
      "vertical_align": "top",
      "offset_x": 60,
      "offset_y": 60,
      "direction": "ltr",
      "img_composite": [
        "7",
        0
      ]
    }
  },
  "9": {
    "class_type": "DrawText+",
    "inputs": {
      "text": "__CTA_TEXT__",
      "font": "ShareTechMono-Regular.ttf",
      "size": 48,
      "color": "#FFD700",
      "background_color": "#00000088",
      "shadow_distance": 3,
      "shadow_blur": 2,
      "shadow_color": "#000000",
      "horizontal_align": "left",
      "vertical_align": "bottom",
      "offset_x": 60,
      "offset_y": -60,
      "direction": "ltr",
      "img_composite": [
        "8",
        0
      ]
    }
  },
  "10": {
    "class_type": "SaveImage",
    "inputs": {
      "images": [
        "9",
        0
      ],
      "filename_prefix": "thumbnail"
    }
  }
}
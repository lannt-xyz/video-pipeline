{
  "_meta": {
    "description": "Thumbnail base image \u2014 16:9 (1280x720). Title/CTA text overlay is applied in Python (Pillow) AFTER generation because the ComfyUI DrawText+ node only ships ShareTechMono which lacks Vietnamese diacritics.",
    "checkpoint": "dreamshaperXL_lightningDPMSDE.safetensors",

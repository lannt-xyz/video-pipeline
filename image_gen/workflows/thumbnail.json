      "NEGATIVE_PROMPT": "Negative prompt",
      "WIDTH": 1280,
      "HEIGHT": 720,
      "SEED": 42
    },
    "required_nodes": [
      "CheckpointLoaderSimple",
      "CLIPTextEncode",
      "KSampler",
      "VAEDecode",
      "SaveImage"
    ]
  },
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "dreamshaperXL_lightningDPMSDE.safetensors"
    }
  },
  "3": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "__SCENE_PROMPT__, masterpiece, best quality, cinematic, wide shot, bright key light, vivid color grading",
      "clip": [
        "1",
        1
      ]
    }
  },
  "4": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "__NEGATIVE_PROMPT__, nsfw, underexposed, dark scene, murky shadows",
      "clip": [
        "1",
        1
      ]
    }
  },
  "5": {
    "class_type": "EmptyLatentImage",
    "inputs": {
      "width": "__WIDTH__",
      "height": "__HEIGHT__",
      "batch_size": 1
    }
  },
  "6": {
    "class_type": "KSampler",
    "inputs": {
      "model": [
        "1",
        0
      ],
      "positive": [
        "3",
        0
      ],
      "negative": [
        "4",
        0
      ],
      "latent_image": [
        "5",
        0
      ],
      "seed": "__SEED__",
      "steps": 8,
      "cfg": 2.0,
      "sampler_name": "dpmpp_sde",
      "scheduler": "karras",
      "denoise": 1.0
    }
  },
  "7": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": [
        "6",
        0
      ],
      "vae": [
        "1",
        2
      ]
    }
  },
  "8": {
    "class_type": "SaveImage",
    "inputs": {
      "images": [
        "7",
        0
      ],
      "filename_prefix": "thumbnail"
    }
  }
